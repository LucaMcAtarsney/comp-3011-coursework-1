  "components": {
    "schemas": {
      "GenerateNameResponse": {
        "properties": {
          "player_name": {
            "type": "string",
            "title": "Player Name"
          }
        },
        "type": "object",
        "required": [
          "player_name"
        ],
        "title": "GenerateNameResponse",
        "description": "Schema for the response when generating a random player name."
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "NameCheckRequest": {
        "properties": {
          "player_name": {
            "type": "string",
            "title": "Player Name"
          }
        },
        "type": "object",
        "required": [
          "player_name"
        ],
        "title": "NameCheckRequest",
        "description": "Schema for a request to check if a player name is available."
      },
      "NameCheckResponse": {
        "properties": {
          "exists": {
            "type": "boolean",
            "title": "Exists"
          },
          "message": {
            "type": "string",
            "title": "Message"
          }
        },
        "type": "object",
        "required": [
          "exists",
          "message"
        ],
        "title": "NameCheckResponse",
        "description": "Schema for the response when checking a player name."
      },
      "Player": {
        "properties": {
          "name": {
            "type": "string",
            "title": "Name"
          },
          "id": {
            "type": "integer",
            "title": "Id"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "title": "Created At"
          }
        },
        "type": "object",
        "required": [
          "name",
          "id",
          "created_at"
        ],
        "title": "Player",
        "description": "Schema for representing a player, including their ID and creation date."
      },
      "PlayerCreate": {
        "properties": {
          "name": {
            "type": "string",
            "title": "Name"
          }
        },
        "type": "object",
        "required": [
          "name"
        ],
        "title": "PlayerCreate",
        "description": "Schema for creating a new player. Currently, it's the same as the base."
      },
      "PlayerCreateResponse": {
        "properties": {
          "name": {
            "type": "string",
            "title": "Name"
          },
          "id": {
            "type": "integer",
            "title": "Id"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "title": "Created At"
          },
          "password": {
            "type": "string",
            "title": "Password"
          }
        },
        "type": "object",
        "required": [
          "name",
          "id",
          "created_at",
          "password"
        ],
        "title": "PlayerCreateResponse",
        "description": "Schema for the response when a new player is created.\nIt includes the player's details and their generated password."
      },
      "PlayerNameUpdate": {
        "properties": {
          "name": {
            "type": "string",
            "title": "Name"
